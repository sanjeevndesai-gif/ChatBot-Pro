# ================================================================
# ChatBot-Pro — Environment Variables Template
# ================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env — it is in .gitignore
# ================================================================

# ---- JWT Secret ----
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-a-256bit-random-secret

# ---- OAuth2 Client Credentials ----
OAUTH2_CLIENT_ID=chatbot-client
OAUTH2_CLIENT_SECRET=change-me-strong-oauth2-secret

# ---- MongoDB URIs ----
# Local dev (Docker):  mongodb://mongo:27017/<db>
# Production:          mongodb+srv://user:pass@cluster.mongodb.net/<db>
MONGO_URI_AUTH=mongodb://mongo:27017/auth-service
MONGO_URI_BOOK=mongodb://mongo:27017/book_appointment
MONGO_URI_CHAT=mongodb://mongo:27017/chatdb
MONGO_URI_I18N=mongodb://mongo:27017/i18n-service

# ---- Eureka Service Discovery ----
# Local dev: http://eureka-server:8761/eureka/
# Prod ECS:  http://<eureka-ecs-hostname>:8761/eureka/
EUREKA_URL=http://eureka-server:8761/eureka/

# ---- WhatsApp Cloud API ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---- OpenAI (optional) ----
OPENAI_API_KEY=