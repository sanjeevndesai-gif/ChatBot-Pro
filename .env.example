# .env.example
# ---------------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control — it is in .gitignore.
# ---------------------------------------------------------------

# ============================================================
# Shared secrets (all profiles)
# ============================================================
JWT_SECRET=ARNAN_AUTH_SERVICE_ULTRA_SECURE_SECRET_2026!!
OAUTH2_CLIENT_ID=chatbot-client
OAUTH2_CLIENT_SECRET=chatbot-secret

# ============================================================
# DEV environment — used with docker-compose.dev.yml
# ============================================================

# auth-service MongoDB (dev)
DEV_MONGODB_URI=mongodb+srv://<user>:<password>@dev-cluster.mongodb.net/auth-service?retryWrites=true&w=majority

# book_appointment MongoDB (dev)
DEV_MONGODB_URI_BOOK=mongodb+srv://<user>:<password>@dev-cluster.mongodb.net/book_appointment?retryWrites=true&w=majority

# chat MongoDB (dev)
DEV_MONGODB_URI_CHAT=mongodb+srv://<user>:<password>@dev-cluster.mongodb.net/chatdb?retryWrites=true&w=majority

# i18n-service MongoDB (dev)
DEV_MONGODB_URI_I18N=mongodb+srv://<user>:<password>@dev-cluster.mongodb.net/i18n-service?retryWrites=true&w=majority

# Redis (dev) — e.g. Redis Cloud or ElastiCache
DEV_REDIS_HOST=dev-redis-host
DEV_REDIS_PORT=6379
DEV_REDIS_PASSWORD=

# ============================================================
# PROD environment — used with docker-compose.prod.yml
# ============================================================

# auth-service MongoDB (prod)
PROD_MONGODB_URI=mongodb+srv://<user>:<password>@prod-cluster.mongodb.net/auth-service?retryWrites=true&w=majority

# book_appointment MongoDB (prod)
PROD_MONGODB_URI_BOOK=mongodb+srv://<user>:<password>@prod-cluster.mongodb.net/book_appointment?retryWrites=true&w=majority

# chat MongoDB (prod)
PROD_MONGODB_URI_CHAT=mongodb+srv://<user>:<password>@prod-cluster.mongodb.net/chatdb?retryWrites=true&w=majority

# i18n-service MongoDB (prod)
PROD_MONGODB_URI_I18N=mongodb+srv://<user>:<password>@prod-cluster.mongodb.net/i18n-service?retryWrites=true&w=majority

# Redis (prod) — e.g. Redis Cloud or ElastiCache
PROD_REDIS_HOST=prod-redis-host
PROD_REDIS_PORT=6379
PROD_REDIS_PASSWORD=your-redis-password
